[app]
title = Ngaos Al Falah Ploso
package.name = ngaos_ploso
package.domain = org.alfalah
source.dir = .
source.include_exts = html,css,js,png,jpg,json
version = 1.0
orientation = portrait
fullscreen = 1

# Ikon Aplikasi (Pastikan file icon-512.png ada di repo Anda)
icon.filename = icon-512.png

# Izin yang dibutuhkan aplikasi
android.permissions = INTERNET
android.api = 33
android.minapi = 21
android.archs = arm64-v8a, armeabi-v7a

